# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (or any MongoDB URI)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-32+-random-characters

# ── App URL ───────────────────────────────────────────────────────────────────
# No trailing slash. Use http://localhost:3000 for local dev.
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# ── Gemini AI (required for Fortune Teller + predictions) ────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Email Reminders (optional) ────────────────────────────────────────────────
# Gmail address used as the sender
EMAIL_FROM=you@gmail.com
# Gmail App Password (NOT your account password).
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_PASS=xxxx xxxx xxxx xxxx
# Recipient address for reminder emails
EMAIL_TO=you@gmail.com

# ── Google Calendar Sync (optional) ──────────────────────────────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com/
# Authorised redirect URI must include: <NEXT_PUBLIC_BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
